plt.plot(nan_zscore(sleep_tensor[curr_track]), linewidth=1)
plt.xlabel("Frame (concatenated)")
plt.ylabel("Speed (pix/s)")
plt.title("Speed time series for first ant (TrackID_0000)")
plt.tight_layout()
plt.show()

