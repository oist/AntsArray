]




bodypoint = 0
cam_regex = r"^cam\d+$"
arena_csv_regex = r"^cam\d+_Arena\d+\.csv$"

# ----------------------------
# Helpers
# ----------------------------
def find_node_col(df: pd.DataFrame) -> str:
    for c in ["node", "Bodypoint", "bodypoint", "point", "part"]:
        if c in df.columns:
            return c
    raise RuntimeError(f"No bodypoint/node column found. Columns: {df.columns.tolist()}")

def infer_frame_xy_cols(df: pd.DataFrame):
    frame_col = next((c for c in ["frame", "Frame", "frame_idx"] if c in df.columns), None)
    xcol = next((c for c in ["x", "X", "x_px"] if c in df.columns), None)
    ycol = next((c for c in ["y", "Y", "y_px"] if c in df.columns), None)
    if frame_col is None or xcol is None or ycol is None:
        raise RuntimeError(f"Could not infer frame/x/y columns. Columns: {df.columns.tolist()}")
    return frame_col, xcol, ycol

def nan_aware_speed_from_csv(csv_path: Path, bodypoint=0) -> np.ndarray:
    df = pd.read_csv(csv_path)
    if df.empty:
        return np.array([], dtype=float)

    node_col = find_node_col(df)
    df = df[df[node_col] == bodypoint].copy()
    if df.empty:
        return np.array([], dtype=float)

    frame_col, xcol, ycol = infer_frame_xy_cols(df)

    df[frame_col] = pd.to_numeric(df[frame_col], errors="coerce")
    df[xcol] = pd.to_numeric(df[xcol], errors="coerce")
    df[ycol] = pd.to_numeric(df[ycol], errors="coerce")
    df = (
        df.dropna(subset=[frame_col])
          .sort_values(frame_col)
          .drop_duplicates(subset=[frame_col], keep="first")
    )

    frames = df[frame_col].astype(int).to_numpy()
    x = df[xcol].to_numpy(float)
    y = df[ycol].to_numpy(float)

    if frames.size == 0:
        return np.array([], dtype=float)

    max_f = int(frames.max())
    x_full = np.full(max_f + 1, np.nan, dtype=float)
    y_full = np.full(max_f + 1, np.nan, dtype=float)
    x_full[frames] = x
    y_full[frames] = y

    dx = np.diff(x_full)
    dy = np.diff(y_full)
    valid = (
        np.isfinite(x_full[1:]) & np.isfinite(x_full[:-1]) &
        np.isfinite(y_full[1:]) & np.isfinite(y_full[:-1])
    )

    speed = np.full_like(x_full, np.nan, dtype=float)
    speed[1:][valid] = np.sqrt(dx[valid]**2 + dy[valid]**2)
    return speed

# ----------------------------
# Main with tqdm
# ----------------------------
cam_rx = re.compile(cam_regex)
arena_rx = re.compile(arena_csv_regex)

segments = defaultdict(list)

for folder in tqdm(list(map(Path, folders)), desc="Folders"):
    if not folder.is_dir():
        raise FileNotFoundError(f"Folder not found: {folder}")

    cam_dirs = sorted(p for p in folder.iterdir() if p.is_dir() and cam_rx.match(p.name))
    if not cam_dirs:
        raise RuntimeError(f"No cam dirs found in {folder}")

    for cam_dir in tqdm(cam_dirs, desc=f"{folder.name} cams", leave=False):
        csvs = sorted(p for p in cam_dir.glob("*.csv") if arena_rx.match(p.name))
        if not csvs:
            continue

        for csv_path in tqdm(csvs, desc=f"{cam_dir.name} CSVs", leave=False):
            m = re.match(r"^(cam\d+)_(Arena\d+)\.csv$", csv_path.name)
            if not m:
                continue

            cam_name, arena_name = m.group(1), m.group(2)

            sp = nan_aware_speed_from_csv(csv_path, bodypoint=bodypoint)
            if sp.size == 0:
                continue

            segments[(cam_name, arena_name)].append(sp)

# ----------------------------
# Build concatenated matrix
# ----------------------------
row_keys = sorted(segments.keys())
row_labels = [f"{cam}/{arena}" for cam, arena in row_keys]

row_series = [np.concatenate(segments[k], axis=0) for k in row_keys]

max_len = max(arr.size for arr in row_series)
mat = np.full((len(row_series), max_len), np.nan, dtype=float)

for i, arr in enumerate(row_series):
    mat[i, :arr.size] = arr

print("Matrix shape (n_cam_arena, total_time):", mat.shape)
print("Example rows:", row_labels[:5])



#%%
out_dir = Path("/home/sam-reiter/bucket/ReiterU/Ants/basler/single_ants/single_ant_speed_analysis")
out_dir.mkdir(parents=True, exist_ok=True)

# ---- save raw matrix ----
np.save(out_dir / "antxspeed_concat.npy", mat)


# ---- save row labels ----
pd.DataFrame(
    {
        "row": np.arange(len(row_labels)),
        "label": row_labels,
    }
).to_csv(out_dir / "antxspeed_concat_rows.csv", index=False)

