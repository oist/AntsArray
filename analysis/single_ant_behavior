import numpy as np
import matplotlib.pyplot as plt
from hmmlearn.hmm import GaussianHMM
from scipy.optimize import curve_fit

# ----------------------------
# USER SETTINGS
# ----------------------------
row = 9
fps = 25

# HMM
use_log = True
eps = 1e-6

# Long-timescale inactive from HMM states (bin + threshold)
bin_minutes = 60
inactive_frac_thr = 0.20  # bin is "inactive" if frac_inactive >= this

# Cosinor
period_h = 24.0

# ----------------------------
# 0) Data
# ----------------------------
speed = mat_smooth[row, :].astype(float)
n_frames = speed.size
t_hours = np.arange(n_frames) / fps / 3600.0

# ----------------------------
# 1) Fit 2-state HMM on speed
# ----------------------------
valid = np.isfinite(speed)
speed_valid = speed[valid]
if speed_valid.size < 200:
    raise RuntimeError("Not enough valid samples for HMM.")

X = (np.log(speed_valid + eps) if use_log else speed_valid).reshape(-1, 1)

hmm = GaussianHMM(
    n_components=2,
    covariance_type="diag",
    n_iter=500,
    random_state=0,
)
hmm.fit(X)
states = hmm.predict(X)

means = hmm.means_.flatten()
inactive_state = int(np.argmin(means))
active_state = int(np.argmax(means))

state_full = np.full(n_frames, np.nan)
state_full[valid] = states

print("HMM means:", means, "(log-space)" if use_log else "(speed-space)")
print("inactive_state:", inactive_state, "active_state:", active_state)
print("transmat:\n", hmm.transmat_)

# ----------------------------
# 2) Long-timescale inactive label via bin_threshold on HMM states
# ----------------------------
bin_size = int(bin_minutes * 60 * fps)
n_bins = n_frames // bin_size

bin_centers = np.empty(n_bins, dtype=float)
frac_active = np.full(n_bins, np.nan, dtype=float)
frac_inactive = np.full(n_bins, np.nan, dtype=float)
long_inactive_bin = np.full(n_bins, np.nan, dtype=float)  # per-bin macro label (0/1)

for b in range(n_bins):
    i0 = b * bin_size
    i1 = i0 + bin_size
    bin_centers[b] = np.mean(t_hours[i0:i1])

    st = state_full[i0:i1]
    vv = st[np.isfinite(st)]
    if vv.size == 0:
        continue

    frac_active[b] = np.mean(vv == active_state)
    frac_inactive[b] = np.mean(vv == inactive_state)
    long_inactive_bin[b] = 1.0 if frac_inactive[b] >= inactive_frac_thr else 0.0

# Expand per-bin macro label to per-frame (for shading)
long_inactive_full = np.full(n_frames, np.nan, dtype=float)
for b in range(n_bins):
    i0 = b * bin_size
    i1 = i0 + bin_size
    long_inactive_full[i0:i1] = long_inactive_bin[b]

# ----------------------------
# 3) Cosinor fit on fraction active (binned)
# ----------------------------
def cosinor(t, M, A, phi):
    w = 2 * np.pi / period_h
    return M + A * np.cos(w * t + phi)

fit_mask = np.isfinite(frac_active)
t_fit = bin_centers[fit_mask]
y_fit = frac_active[fit_mask]

cos_params = None
t_dense = None
y_dense = None
t_peak = None
r2 = None

if y_fit.size >= 10:
    M0 = float(np.mean(y_fit))
    A0 = float(0.5 * (np.percentile(y_fit, 95) - np.percentile(y_fit, 5)))
    phi0 = 0.0

    popt, _ = curve_fit(
        cosinor,
        t_fit,
        y_fit,
        p0=[M0, max(A0, 1e-3), phi0],
        bounds=([0.0, 0.0, -2*np.pi], [1.0, 1.0, 2*np.pi]),
        maxfev=20000,
    )
    cos_params = popt
    M, A, phi = popt
    w = 2 * np.pi / period_h
    t_peak = (-phi / w) % period_h

    y_hat = cosinor(t_fit, *popt)
    ss_res = float(np.sum((y_fit - y_hat) ** 2))
    ss_tot = float(np.sum((y_fit - np.mean(y_fit)) ** 2))
    r2 = 1.0 - ss_res / ss_tot if ss_tot > 0 else np.nan

    t_dense = np.linspace(bin_centers[0], bin_centers[-1], 2000)
    y_dense = cosinor(t_dense, *popt)

    print(f"Cosinor 24h on frac_active: M={M:.3f}, A={A:.3f}, peak={t_peak:.2f}h, R^2={r2:.3f}")
else:
    print("Not enough bins for cosinor fit (need >= 10).")

